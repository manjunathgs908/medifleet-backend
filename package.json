{
  "name": "medifleet-crm-backend",
  "version": "1.0.0",
  "description": "MediFleet Ambulance CRM — Production Backend",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "test":    "jest --forceExit --detectOpenHandles",
    "lint":    "eslint . --ext .js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios":             "^1.6.0",
    "bcryptjs":          "^2.4.3",
    "cloudinary":        "^1.41.0",
    "cors":              "^2.8.5",
    "dotenv":            "^16.3.1",
    "express":           "^4.18.2",
    "express-rate-limit":"^7.1.0",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "mongoose":          "^8.0.0",
    "morgan":            "^1.10.0",
    "node-cron":         "^3.0.3"
